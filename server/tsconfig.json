{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "types": ["jest", "node"],
    "skipLibCheck": true
  },
  "include": ["src/core/**/*"],
  "exclude": ["tests/**/*", "node_modules"]
}
